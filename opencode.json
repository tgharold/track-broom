{
    "$schema": "https://opencode.ai/config.json",
    "permission": {
        "bash": {
            "git add *": "allow",
            "git commit -m *": "allow",
            "pip list": "allow",
            "python -m pytest tests/": "allow",
            "PYTHONPATH=src python -m pytest tests/": "allow",
            "uv build": "allow",
            "uv pip install '.[dev]'": "allow",
            "uv pip list": "allow",
            "uv run pytest": "allow",
            "uv sync": "allow"
        }
    }
}